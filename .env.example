# ==============================
# JARVIS — קובץ הגדרות
# העתק קובץ זה ל-.env ומלא את הערכים
# ==============================

# Claude API Key — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Picovoice Access Key (לזיהוי "Hey JARVIS") — https://console.picovoice.ai
PICOVOICE_ACCESS_KEY=...

# שרת JARVIS
JARVIS_PORT=7799
JARVIS_HOST=0.0.0.0

# קול JARVIS (אפשרויות: en-GB-RyanNeural, en-US-GuyNeural)
TTS_VOICE=en-GB-RyanNeural

# מודל Whisper (tiny/base/small/medium) — base = איזון טוב
WHISPER_MODEL=base

# שם קובץ מסד הנתונים
DB_PATH=jarvis_memory.db
